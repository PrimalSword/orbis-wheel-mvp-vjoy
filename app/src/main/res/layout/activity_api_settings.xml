<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Central de APIs"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/apiStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:padding="16dp"
            android:text="Nenhuma integração configurada"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Fonte de dados ativa"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/marketProviderSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Dados de mercado"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/twelveDataApiInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Twelve Data — Secret key"
            android:importantForAutofill="noExcludeDescendants"
            android:inputType="textPassword" />

        <EditText
            android:id="@+id/alphaVantageApiInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Alpha Vantage — API key"
            android:importantForAutofill="noExcludeDescendants"
            android:inputType="textPassword" />

        <EditText
            android:id="@+id/polygonApiInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Polygon.io — API key"
            android:importantForAutofill="noExcludeDescendants"
            android:inputType="textPassword" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Mentor com IA"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/openAiApiInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="OpenAI — API key"
            android:importantForAutofill="noExcludeDescendants"
            android:inputType="textPassword" />

        <EditText
            android:id="@+id/geminiApiInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Gemini — API key"
            android:importantForAutofill="noExcludeDescendants"
            android:inputType="textPassword" />

        <EditText
            android:id="@+id/anthropicApiInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Anthropic — API key"
            android:importantForAutofill="noExcludeDescendants"
            android:inputType="textPassword" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Corretoras e exchanges — opcionais"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/binanceApiInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Binance — API key"
            android:importantForAutofill="noExcludeDescendants"
            android:inputType="textPassword" />

        <EditText
            android:id="@+id/binanceSecretInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Binance — Secret"
            android:importantForAutofill="noExcludeDescendants"
            android:inputType="textPassword" />

        <EditText
            android:id="@+id/oandaTokenInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="OANDA — API token"
            android:importantForAutofill="noExcludeDescendants"
            android:inputType="textPassword" />

        <EditText
            android:id="@+id/oandaAccountInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="OANDA — Account ID"
            android:importantForAutofill="noExcludeDescendants"
            android:inputType="textPassword" />

        <Button
            android:id="@+id/toggleApiVisibilityButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Mostrar chaves" />

        <Button
            android:id="@+id/saveApiButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Salvar com criptografia" />

        <Button
            android:id="@+id/removeApiButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Remover todas as chaves" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="As credenciais não ficam no código nem são enviadas ao GitHub. O armazenamento usa AES-GCM com uma chave protegida pelo Android Keystore. Para corretoras, use apenas permissões de leitura até que a execução de ordens seja implementada e revisada."
            android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

    </LinearLayout>
</ScrollView>
