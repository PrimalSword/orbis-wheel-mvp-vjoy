<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView android:id="@+id/titleText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_horizontal" android:text="ORBISTRADE" android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium" android:textStyle="bold" />
        <TextView android:id="@+id/statusText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_horizontal" android:layout_marginTop="12dp" android:text="Inicializando motor..." android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />
        <Button android:id="@+id/apiSettingsButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="Configurar APIs" />

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="Qual é a sua hipótese antes da análise?" android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />
        <RadioGroup android:id="@+id/thesisGroup" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <RadioButton android:id="@+id/thesisBuy" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Compra" />
            <RadioButton android:id="@+id/thesisSell" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Venda" />
            <RadioButton android:id="@+id/thesisNeutral" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" android:text="Neutro" />
        </RadioGroup>

        <EditText android:id="@+id/balanceInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:hint="Saldo da conta" android:inputType="numberDecimal" android:text="10000" />
        <EditText android:id="@+id/riskInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="Risco por operação (%)" android:inputType="numberDecimal" android:text="1" />
        <Button android:id="@+id/analyzeButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Analisar e aprender" />

        <TextView android:id="@+id/regimeText" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="28dp" android:text="Mercado: --" android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />
        <TextView android:id="@+id/strategyText" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Estratégia: --" android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />
        <TextView android:id="@+id/decisionText" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:padding="16dp" android:text="Decisão: --" android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Gráfico operacional — 5 minutos"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textStyle="bold" />

        <com.orbistrade.app.ui.chart.CandleChartView
            android:id="@+id/candleChart"
            android:layout_width="match_parent"
            android:layout_height="360dp"
            android:layout_marginTop="8dp"
            android:contentDescription="Gráfico de candles com estrutura de mercado e plano operacional" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Candles recentes, pivôs HH/HL/LH/LL, BOS/CHoCH, suporte, resistência, entrada, stop, alvo e padrão predominante."
            android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

        <TextView android:id="@+id/multiTimeframeText" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:padding="16dp" android:text="Filtro multitemporal: --" android:textAppearance="@style/TextAppearance.Material3.BodyLarge" android:textStyle="bold" />
        <TextView android:id="@+id/marketStructureText" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:padding="16dp" android:text="Estrutura de mercado: --" android:textAppearance="@style/TextAppearance.Material3.BodyLarge" android:textStyle="bold" />
        <TextView android:id="@+id/candlestickPatternText" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:padding="16dp" android:text="Padrões de candles: --" android:textAppearance="@style/TextAppearance.Material3.BodyLarge" android:textStyle="bold" />
        <TextView android:id="@+id/setupScoreText" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:padding="16dp" android:text="Qualidade do setup: --" android:textAppearance="@style/TextAppearance.Material3.BodyLarge" android:textStyle="bold" />
        <TextView android:id="@+id/mentorText" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:padding="16dp" android:text="Modo mentor: --" android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />
        <TextView android:id="@+id/riskPlanText" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:padding="16dp" android:text="Plano de risco: --" android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />
        <TextView android:id="@+id/entrySetupText" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:padding="16dp" android:text="Setup condicional de entrada: --" android:textAppearance="@style/TextAppearance.Material3.BodyLarge" android:textStyle="bold" />
        <TextView android:id="@+id/biasReviewText" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:padding="16dp" android:text="Revisão contra viés de confirmação: --" android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />
    </LinearLayout>
</ScrollView>
